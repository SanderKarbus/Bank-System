{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "volumeMounts": [
      {
        "mountPath": "/data",
        "volumeName": "bank-data"
      }
    ]
  },
  "volumes": [
    {
      "name": "bank-data",
      "filesystem": "ephemeral"
    }
  ]
}
